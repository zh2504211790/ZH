desktop_path = r"C:\Users\25042\Desktop"
train_path = os.path.join(desktop_path, "训练集.csv")
test_path = os.path.join(desktop_path, "测试集.csv")
facility_path = os.path.join(desktop_path, "贵阳市全区域基础设施数据.csv")
GUIYANG_CENTER = (26.647, 106.630)
class FacilityFeatureTransformer(BaseEstimator, TransformerMixin):
    def __init__(self, facility_data, radius=1.0):
        self.facility_data = facility_data
        self.radius = radius
        self.facility_categories = None
        self.trees = {}

    def fit(self, X, y=None):
        self.facility_categories = self.facility_data['主类别'].unique()
        facilities_rad = np.deg2rad(self.facility_data[['纬度', '经度']].values)
        for category in self.facility_categories:
            category_mask = (self.facility_data['主类别'] == category)
            self.trees[category] = BallTree(facilities_rad[category_mask], metric='haversine')
        return self

    def transform(self, X, y=None):
        X = X.copy()
        for cat in self.facility_categories:
            X[f'设施_{cat}_1km'] = 0
        house_rad = np.deg2rad(X[['纬度', '经度']].values)
        for i in range(len(house_rad)):
            for cat, tree in self.trees.items():
                indices = tree.query_radius([house_rad[i]], r=self.radius / 6371)[0]
                X.iloc[i, X.columns.get_loc(f'设施_{cat}_1km')] = len(indices)
            if (i + 1) % 500 == 0:
                print(f"已处理 {i + 1}/{len(X)} 条记录")
        return X

def load_data():
    print("正在加载训练集和测试集...")
    train = pd.read_csv(train_path)
    test = pd.read_csv(test_path)
    features = [
        '房屋面积', '总楼层', '房间数量', '厅数量',
        '朝向_东', '朝向_南', '朝向_西', '朝向_北',
        '朝向_东南', '朝向_西南', '朝向_东北', '朝向_西北',
        '所在楼层_中楼层', '所在楼层_低楼层', '所在楼层_高楼层',
        '房屋结构_塔楼', '房屋结构_平房', '房屋结构_板塔结合', '房屋结构_板楼',
        '装修情况_毛坯', '装修情况_简装', '装修情况_精装',
        '成交季节_旺季', '成交季节_淡季', '成交季节_过渡月',
        '总价', '纬度', '经度'
    ]
    train = train[[col for col in features if col in train.columns]]
    test = test[[col for col in features if col in test.columns]]
    print(f"训练集大小: {train.shape}, 测试集大小: {test.shape}")
    print("正在加载基础设施数据...")
    try:
        facilities = pd.read_csv(facility_path, encoding='gbk')
    except:
        try:
            facilities = pd.read_csv(facility_path, encoding='gb2312')
        except:
            try:
                facilities = pd.read_csv(facility_path, encoding='utf-8')
            except:
                try:
                    facilities = pd.read_csv(facility_path, encoding='latin1')
                except:
                    facilities = pd.read_csv(facility_path, encoding='ISO-8859-1')
    facilities = facilities.dropna(subset=['纬度', '经度'])
    facilities['纬度'] = pd.to_numeric(facilities['纬度'], errors='coerce')
    facilities['经度'] = pd.to_numeric(facilities['经度'], errors='coerce')
    facilities = facilities.dropna(subset=['纬度', '经度'])
    print(f"基础设施数据大小: {facilities.shape}")
    print(f"基础设施类别数量: {facilities['主类别'].nunique()}")
    print("基础设施类别:", facilities['主类别'].unique())
    return train, test, facilities

def add_features(df):
    df = df.copy()
    df['单价'] = df['总价'] / df['房屋面积']
    df['房间总数'] = df['房间数量'] + df['厅数量']
    def calc_distance(row):
        try:
            return haversine((row['纬度'], row['经度']), GUIYANG_CENTER)
        except:
            return np.nan
    df['距市中心距离'] = df.apply(calc_distance, axis=1)
    return df

def prepare_data(train, test, facilities):
    print("\n添加高级特征...")
    train = add_features(train)
    test = add_features(test)
    print("\n计算周边设施特征...")
    start_time = time.time()
    facility_transformer = FacilityFeatureTransformer(facilities, radius=1.0)
    facility_transformer.fit(train)
    train = facility_transformer.transform(train)
    test = facility_transformer.transform(test)
    total_time = time.time() - start_time
    print(f"设施特征计算完成! 总耗时: {total_time:.2f}秒")
    X_train = train.drop('总价', axis=1)
    y_train = train['总价']
    X_test = test.drop('总价', axis=1)
    y_test = test['总价']
    scaler = StandardScaler()
    X_train_scaled = scaler.fit_transform(X_train)
    X_test_scaled = scaler.transform(X_test)
    print("\n数据准备完成!")
    print(f"训练集特征: {X_train.shape}, 测试集特征: {X_test.shape}")
    return X_train_scaled, X_test_scaled, y_train, y_test, scaler, X_train.columns.tolist()

def train_model(X_train, X_test, y_train, y_test):
    print("\n开始训练线性回归模型...")
    model = LinearRegression()
    CV_FOLDS = 5
    cv_r2_scores = cross_val_score(model, X_train, y_train, cv=CV_FOLDS, scoring='r2')
    cv_mae_scores = -cross_val_score(model, X_train, y_train, cv=CV_FOLDS, scoring='neg_mean_absolute_error')
    cv_r2_mean = cv_r2_scores.mean()
    cv_mae_mean = cv_mae_scores.mean()
    print(f"\n===== {CV_FOLDS} 折交叉验证结果 =====")
    print(f"每折 R²: {cv_r2_scores.round(4)}")
    print(f"交叉验证平均 R²: {cv_r2_mean:.4f}")
    print(f"交叉验证平均 MAE: {cv_mae_mean:.4f} 万元")
    model.fit(X_train, y_train)
    y_pred = model.predict(X_test)
    test_r2 = r2_score(y_test, y_pred)
    test_mae = mean_absolute_error(y_test, y_pred)
    test_mape = np.mean(np.abs((y_test - y_pred) / np.maximum(np.abs(y_test), 1))) * 100
    print("\n===== 测试集评估结果 =====")
    print(f"R² 得分: {test_r2:.4f}")
    print(f"平均绝对误差: {test_mae:.4f} 万元")
    print(f"平均绝对百分比误差: {test_mape:.2f} %")
    return model, y_pred, cv_r2_mean, cv_mae_mean

def plot_feature_importance(model, feature_names):
    coef = model.coef_
    importance = np.abs(coef)
    if len(importance) != len(feature_names):
        print(f"警告: 特征名称数量({len(feature_names)})与系数数量({len(importance)})不一致")
        min_len = min(len(importance), len(feature_names))
        importance = importance[:min_len]
        feature_names = feature_names[:min_len]
    indices = np.argsort(importance)[-15:]
    plt.figure(figsize=(12, 8))
    plt.barh(range(len(indices)), importance[indices], color='b', align='center')
    plt.yticks(range(len(indices)), [feature_names[i] for i in indices])
    plt.xlabel('特征重要性（系数绝对值）')
    plt.title('线性回归特征重要性')
    plt.tight_layout()
    plt.savefig(os.path.join(desktop_path, '特征重要性.png'), dpi=300)
    plt.close()
    print("特征重要性图已保存至桌面")

def plot_prediction_comparison(y_true, y_pred):
    plt.figure(figsize=(15, 8))
    plt.plot(y_true.values, label='真实房价',
             marker='o', markersize=3, linestyle='-', alpha=0.6)
    plt.plot(y_pred, label='预测房价',
             marker='x', markersize=3, linestyle='-', alpha=0.6)
    plt.xlabel('测试集全部样本')
    plt.ylabel('房价(万元)')
    plt.title('房价预测值与真实值对比（全部样本）')
    plt.legend()
    plt.grid(True, linestyle='--', alpha=0.6)  # 修复这里！
    plt.tight_layout()
    plt.savefig(os.path.join(desktop_path, '预测对比（全部样本）.png'), dpi=300)
    plt.close()
    print("预测对比图（全部样本）已保存至桌面")
    plt.figure(figsize=(12, 6))
    n_samples = min(100, len(y_true))
    sample_idx = range(n_samples)
    plt.plot(y_true.iloc[sample_idx].values, label='真实房价',
             marker='o', markersize=4, linestyle='-', alpha=0.7)
    plt.plot(y_pred[sample_idx], label='预测房价',
             marker='x', markersize=4, linestyle='-', alpha=0.7)
    plt.xlabel(f'测试集前{n_samples}样本')
    plt.ylabel('房价(万元)')
    plt.title(f'房价预测值与真实值对比（前{n_samples}样本）')
    plt.legend()
    plt.grid(True, linestyle='--', alpha=0.6)
    plt.tight_layout()
    plt.savefig(os.path.join(desktop_path, f'预测对比（前{n_samples}样本）.png'), dpi=300)
    plt.close()
    print(f"预测对比图（前{n_samples}样本）已保存至桌面")

def save_results(model, y_pred, y_test, feature_names, scaler):
    mape_array = np.abs((y_pred - y_test) / np.maximum(np.abs(y_test), 1)) * 100
    total_samples = len(y_test)
    count_5 = np.sum(mape_array < 5)
    count_10 = np.sum(mape_array < 10)
    count_20 = np.sum(mape_array < 20)
    ratio_5 = count_5 / total_samples * 100
    ratio_10 = count_10 / total_samples * 100
    ratio_20 = count_20 / total_samples * 100

    print("\n" + "-" * 60)
    print("MAPE 精度样本统计：")
    print(f"MAPE < 5%  样本数：{count_5}/{total_samples}，占比：{ratio_5:.2f}%")
    print(f"MAPE < 10% 样本数：{count_10}/{total_samples}，占比：{ratio_10:.2f}%")
    print(f"MAPE < 20% 样本数：{count_20}/{total_samples}，占比：{ratio_20:.2f}%")
    print("-" * 60)

    result = pd.DataFrame({
        '真实总价': y_test.values,
        '预测总价': y_pred,
        '误差': y_pred - y_test.values,
        'MAPE(%)': mape_array,
        'MAPE<5%': mape_array < 5,
        'MAPE<10%': mape_array < 10,
        'MAPE<20%': mape_array < 20
    })
    result_path = os.path.join(desktop_path, '房价预测结果.csv')
    result.to_csv(result_path, index=False, encoding='utf-8-sig')
    print(f"预测结果已保存至: {result_path}")

    model_path = os.path.join(desktop_path, '房价预测模型.pkl')
    joblib.dump(model, model_path)
    print(f"模型已保存至: {model_path}")

    scaler_path = os.path.join(desktop_path, '特征标准化器.pkl')
    joblib.dump(scaler, scaler_path)
    print(f"特征标准化器已保存至: {scaler_path}")

    coef = model.coef_
    min_len = min(len(coef), len(feature_names))
    feature_importance = pd.DataFrame({
        '特征': feature_names[:min_len],
        '系数': coef[:min_len],
        '重要性': np.abs(coef[:min_len])
    }).sort_values('重要性', ascending=False)

    feature_path = os.path.join(desktop_path, '特征重要性.csv')
    feature_importance.to_csv(feature_path, index=False, encoding='utf-8-sig')
    print(f"特征重要性数据已保存至: {feature_path}")

    mape_stats = pd.DataFrame({
        '指标': ['总样本数', 'MAPE<5%样本数', 'MAPE<10%样本数', 'MAPE<20%样本数',
                 'MAPE<5%占比(%)', 'MAPE<10%占比(%)', 'MAPE<20%占比(%)'],
        '数值': [total_samples, count_5, count_10, count_20, ratio_5, ratio_10, ratio_20]
    })
    mape_stats_path = os.path.join(desktop_path, 'MAPE精度统计.csv')
    mape_stats.to_csv(mape_stats_path, index=False, encoding='utf-8-sig')
    print(f"MAPE精度统计已保存至: {mape_stats_path}")

def main():
    start_time = time.time()
    print("=" * 50)
    print("贵阳市房价预测模型（线性回归 + 3折交叉验证）")
    print("=" * 50)

    print("\n[阶段一] 数据加载")
    train, test, facilities = load_data()

    print("\n[阶段二] 特征工程")
    X_train, X_test, y_train, y_test, scaler, feature_names = prepare_data(train, test, facilities)

    print("\n[阶段三] 模型训练与评估")
    model, y_pred, cv_r2_mean, cv_mae_mean = train_model(X_train, X_test, y_train, y_test)

    print("\n[阶段四] 可视化与保存结果")
    plot_feature_importance(model, feature_names)
    plot_prediction_comparison(y_test, y_pred)
    save_results(model, y_pred, y_test, feature_names, scaler)

    total_time = time.time() - start_time
    minutes, seconds = divmod(total_time, 60)
    print(f"\n{'=' * 50}")
    print(f"处理完成! 总耗时: {int(minutes)}分{seconds:.2f}秒")
    print("=" * 50)

    test_r2 = r2_score(y_test, y_pred)
    test_mae = mean_absolute_error(y_test, y_pred)
    test_mape = np.mean(np.abs((y_test - y_pred) / np.maximum(np.abs(y_test), 1))) * 100

    print(f"\n最终模型性能:")
    print(f"3 折交叉验证平均 R²: {cv_r2_mean:.4f}")
    print(f"测试集 R² 得分: {test_r2:.4f}")
    print(f"平均绝对误差(MAE): {test_mae:.2f} 万元")
    print(f"平均绝对百分比误差(MAPE): {test_mape:.2f} %")
    print("\n注：模型预测结果和特征重要性已保存至桌面")


if __name__ == "__main__":
    main()
