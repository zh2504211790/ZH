def read_csv_auto_encoding(filepath):
    encodings = ['utf-8', 'gbk', 'gb18030', 'utf-8-sig']
    for enc in encodings:
        try:
            return pd.read_csv(filepath, encoding=enc)
        except (UnicodeDecodeError, LookupError):
            continue
    raise ValueError(f"无法读取文件 {filepath}")

def haversine_vec(lat1, lon1, lat2, lon2):
    R = 6371000.0
    lat1, lon1, lat2, lon2 = map(np.radians, [lat1, lon1, lat2, lon2])
    dlat = lat2[:, None] - lat1
    dlon = lon2[:, None] - lon1
    a = np.sin(dlat / 2.0) ** 2 + np.cos(lat1) * np.cos(lat2[:, None]) * np.sin(dlon / 2.0) ** 2
    c = 2 * np.arctan2(np.sqrt(a), np.sqrt(1 - a))
    return R * c

def calculate_infrastructure_features(df_house_input):
    print("\n" + "=" * 60)
    print("正在计算 1公里内基础设施特征...")
    print("=" * 60)
    try:
        df_infra = read_csv_auto_encoding(INFRA_FILE)
    except Exception as e:
        print(f"读取基建数据失败: {e}，跳过此步骤")
        return df_house_input

    df_infra[COL_INFRA_LAT] = pd.to_numeric(df_infra[COL_INFRA_LAT], errors="coerce")
    df_infra[COL_INFRA_LON] = pd.to_numeric(df_infra[COL_INFRA_LON], errors="coerce")
    df_infra = df_infra.dropna(subset=[COL_INFRA_LAT, COL_INFRA_LON]).reset_index(drop=True)
    df_house = df_house_input.copy()
    temp_lats = pd.to_numeric(df_house[COL_HOUSE_LAT], errors="coerce").values
    temp_lons = pd.to_numeric(df_house[COL_HOUSE_LON], errors="coerce").values
    df_house['_temp_row_id'] = range(len(df_house))
    has_category = COL_INFRA_CATEGORY in df_infra.columns
    infra_categories = sorted(df_infra[COL_INFRA_CATEGORY].unique().tolist()) if has_category else []
    BATCH_SIZE = 2000
    num_batches = int(math.ceil(len(df_house) / BATCH_SIZE))
    infra_results_list = []
    for batch_idx in tqdm(range(num_batches), desc="计算进度"):
        start_idx = batch_idx * BATCH_SIZE
        end_idx = min((batch_idx + 1) * BATCH_SIZE, len(df_house))
        batch_ids = df_house['_temp_row_id'].iloc[start_idx:end_idx].values
        batch_lats = temp_lats[start_idx:end_idx]
        batch_lons = temp_lons[start_idx:end_idx]
        valid_mask = ~np.isnan(batch_lats) & ~np.isnan(batch_lons)
        dist_matrix = None
        if np.any(valid_mask):
            dist_matrix = haversine_vec(batch_lats[valid_mask], batch_lons[valid_mask], df_infra[COL_INFRA_LAT].values, df_infra[COL_INFRA_LON].values)
        for i in range(len(batch_ids)):
            res = {'_temp_row_id': batch_ids[i]}
            if valid_mask[i]:
                lat1, lon1 = batch_lats[i], batch_lons[i]
                if not np.isnan(lat1) and not np.isnan(lon1):
                    lats2 = df_infra[COL_INFRA_LAT].values
                    lons2 = df_infra[COL_INFRA_LON].values
                    R = 6371000.0
                    p1 = np.radians(lat1)
                    p2 = np.radians(lats2)
                    dp = np.radians(lats2 - lat1)
                    dl = np.radians(lons2 - lon1)
                    a = np.sin(dp / 2) ** 2 + np.cos(p1) * np.cos(p2) * np.sin(dl / 2) ** 2
                    c = 2 * np.arctan2(np.sqrt(a), np.sqrt(1 - a))
                    dists = R * c
                    nearby_mask = dists <= DISTANCE_THRESHOLD
                    res['1公里内基建总数'] = int(np.sum(nearby_mask))
                    if has_category:
                        nearby_cats = df_infra.loc[nearby_mask, COL_INFRA_CATEGORY]
                        cat_counts = nearby_cats.value_counts()
                        for cat in infra_categories:
                            res[f'1公里内_{cat}数量'] = int(cat_counts.get(cat, 0))
                else:
                    res['1公里内基建总数'] = 0
            else:
                res['1公里内基建总数'] = 0
            infra_results_list.append(res)

    df_infra_result = pd.DataFrame(infra_results_list)
    df_final = pd.merge(df_house, df_infra_result, on='_temp_row_id', how='left')
    df_final = df_final.drop('_temp_row_id', axis=1)
    fill_cols = [c for c in df_final.columns if '1公里内' in c]
    df_final[fill_cols] = df_final[fill_cols].fillna(0)
    print("✅ 基础设施特征计算完成，已合并入数据")
    return df_final

