def plot_season_distribution(data, save_dir):
    if '成交季节' not in data.columns or data.empty:
        print("警告：数据中不包含'成交季节'列，无法绘制成交季节分布柱状图")
        return
    season_counts = data['成交季节'].value_counts().reindex(['旺季', '淡季', '过渡月'], fill_value=0)
    plt.figure(figsize=(10, 6))
    bars = plt.bar(season_counts.index, season_counts.values, color=['#4D4D4D', '#969696', '#D9D9D9'])
    for bar in bars:
        height = bar.get_height()
        plt.text(bar.get_x() + bar.get_width() / 2., height + 5,
                 f'{height}', ha='center', va='bottom', fontsize=12)
    plt.title('二手房成交季节分布', fontsize=16)
    plt.xlabel('季节类型', fontsize=14)
    plt.ylabel('数量', fontsize=14)
    plt.ylim(0, max(season_counts.values) * 1.1 if max(season_counts.values) > 0 else 1)
    plt.grid(axis='y', linestyle='--', alpha=0.7)
    save_path = os.path.join(save_dir, '成交季节分布柱状图.png')
    plt.tight_layout()
    plt.savefig(save_path, dpi=300)
    plt.close()
    print(f"成交季节分布柱状图已保存至: {save_path}")

