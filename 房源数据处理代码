    plt.ylim(0, max(floor_counts.values) * 1.1 if max(floor_counts.values) > 0 else 1)
    plt.grid(axis='y', linestyle='--', alpha=0.7)
    save_path = os.path.join(save_dir, '楼层分布柱状图.png')
    plt.tight_layout()
    plt.savefig(save_path, dpi=300)
    plt.close()
    print(f"楼层分布柱状图已保存至: {save_path}")

