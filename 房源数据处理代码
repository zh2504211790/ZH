def check_data_quality(data):
    if data.empty:
        print("\n数据质量检查：数据为空，无法检查")
        return
    print("\n数据质量检查（目标字段）:")
    target_cols = ['区域', '房屋面积', '总价', '单价', '所在楼层', '总楼层', '房屋结构', '装修情况', '纬度', '经度',
                   '房间数量', '厅数量', '成交月份']
    target_cols += [f'朝向_{o}' for o in VALID_ORIENTATIONS]
    infra_cols = [c for c in data.columns if '1公里内' in c]
    target_cols += infra_cols
    target_cols = [col for col in target_cols if col in data.columns]
