facility_path = os.path.join(desktop_path, "贵阳市全区域基础设施数据.csv")
GUIYANG_CENTER = (26.647, 106.630)
class FacilityFeatureTransformer(BaseEstimator, TransformerMixin):
    def __init__(self, facility_data, radius=1.0):
        self.facility_data = facility_data
        self.radius = radius
        self.facility_categories = None
        self.trees = {}
    def fit(self, X, y=None):
        self.facility_categories = self.facility_data['主类别'].unique()
        facilities_rad = np.deg2rad(self.facility_data[['纬度', '经度']].values)
        for category in self.facility_categories:
            category_mask = (self.facility_data['主类别'] == category)
            self.trees[category] = BallTree(facilities_rad[category_mask], metric='haversine')
        return self

    def transform(self, X, y=None):
        X = X.copy()
        house_rad = np.deg2rad(X[['纬度', '经度']].values)
        r = self.radius / 6371
        for cat, tree in self.trees.items():
            count_list = tree.query_radius(house_rad, r=r, count_only=True)
            X[f'设施_{cat}_1km'] = count_list
        return X

def load_data():
    print("正在加载数据...")
    train = pd.read_csv(train_path)
    test = pd.read_csv(test_path)
    features = [
        '房屋面积', '总楼层', '房间数量', '厅数量',
        '朝向_东', '朝向_南', '朝向_西', '朝向_北',
        '朝向_东南', '朝向_西南', '朝向_东北', '朝向_西北',
        '所在楼层_中楼层', '所在楼层_低楼层', '所在楼层_高楼层',
        '房屋结构_塔楼', '房屋结构_平房', '房屋结构_板塔结合', '房屋结构_板楼',
        '装修情况_毛坯', '装修情况_简装', '装修情况_精装',
        '成交季节_旺季', '成交季节_淡季', '成交季节_过渡月',
        '总价', '纬度', '经度'
    ]
    valid_features_train = [col for col in features if col in train.columns]
    valid_features_test = [col for col in features if col in test.columns]
    train = train[valid_features_train]
    test = test[valid_features_test]
    encodings = ['gbk', 'gb2312', 'utf-8', 'utf-8-sig']
    facilities = None
    for enc in encodings:
        try:
            facilities = pd.read_csv(facility_path, encoding=enc)
            break
        except:
            continue
    facilities = facilities.dropna(subset=['纬度', '经度'])
    facilities['纬度'] = pd.to_numeric(facilities['纬度'], errors='coerce')
    facilities['经度'] = pd.to_numeric(facilities['经度'], errors='coerce')
    facilities = facilities.dropna(subset=['纬度', '经度'])
    return train, test, facilities

def add_features(df):
    df = df.copy()
    df['单价'] = df['总价'] / df['房屋面积'].replace(0, np.nan)
    df['房间总数'] = df['房间数量'] + df['厅数量']
    df['距市中心距离'] = df.apply(lambda x: haversine((x['纬度'], x['经度']), GUIYANG_CENTER), axis=1)
    df.replace([np.inf, -np.inf], np.nan, inplace=True)
    df.fillna(0, inplace=True)
    return df

def prepare_data(train, test, facilities):
    train = add_features(train)
    test = add_features(test)
    transformer = FacilityFeatureTransformer(facilities, radius=1.0)
    train = transformer.fit_transform(train)
    test = transformer.transform(test)
    common_features = [col for col in train.columns if col in test.columns and col != '总价']
    X_train = train[common_features]
    y_train = train['总价']
    X_test = test[common_features]
    y_test = test['总价']
    return X_train, X_test, y_train, y_test

def train_model_paper_strategy(X_train, X_test, y_train, y_test):
    print("\n" + "=" * 60)
    print("XGBoost模型")
    print("=" * 60)
    CV_FOLDS = 5
    RANDOM_STATE = 90
    device_config = {'n_jobs': 1}
    best_params = {}
    start_total_time = time.time()
    print("\n[步骤 1/7] 调优 n_estimators ...")
    superpa = []
    n_estimators_range = range(1, 2001, 100)
    for i in n_estimators_range:
        model = XGBRegressor(
            n_estimators=i + 1,
            random_state=RANDOM_STATE,
            verbosity=0,
            **device_config
        )
        score = cross_val_score(model, X_train, y_train, cv=CV_FOLDS, scoring='r2').mean()
        superpa.append(score)
        print(f"n_estimators={i + 1}, CV R²={score:.4f}")
    best_n_estimators_idx = superpa.index(max(superpa))
    best_n_estimators = list(n_estimators_range)[best_n_estimators_idx] + 1
    best_params['n_estimators'] = best_n_estimators
    print(f"\n步骤1完成：最优 n_estimators = {best_n_estimators}, 最高CV R² = {max(superpa):.4f}")
    plt.figure(figsize=[20, 5])
    plt.plot(n_estimators_range, superpa, marker='o')
    plt.title('n_estimators 学习曲线')
    plt.xlabel('n_estimators')
    plt.ylabel('CV R² Score')
    plt.grid(True)
    plt.savefig(os.path.join(desktop_path, '步骤1_n_estimators学习曲线.png'), dpi=300)
    plt.close()
    print("学习曲线已保存至桌面")

    print("\n[步骤 2/7] 粗调 max_depth & min_child_weight ...")
    param_grid_stage2 = {
        'max_depth': np.arange(3, 8, 2),
        'min_child_weight': [1, 3, 5]
    }
    model_stage2 = XGBRegressor(
        n_estimators=best_params['n_estimators'],
        random_state=RANDOM_STATE,
        verbosity=0,
        **device_config
    )
    grid_stage2 = GridSearchCV(model_stage2, param_grid_stage2, cv=CV_FOLDS, scoring='r2', n_jobs=1, verbose=1)
    grid_stage2.fit(X_train, y_train)
    best_params['max_depth'] = grid_stage2.best_params_['max_depth']
    best_params['min_child_weight'] = grid_stage2.best_params_['min_child_weight']
    print(
        f"步骤2完成：粗调最优 max_depth={best_params['max_depth']}, min_child_weight={best_params['min_child_weight']}, CV R²={grid_stage2.best_score_:.4f}")

    print("\n[步骤 3/7] 精调 max_depth & min_child_weight ...")
    current_md = best_params['max_depth']
    current_mcw = best_params['min_child_weight']
    param_grid_stage3 = {
        'max_depth': [current_md - 1, current_md, current_md + 1],
        'min_child_weight': [current_mcw - 1, current_mcw, current_mcw + 1]
    }
    param_grid_stage3['max_depth'] = [x for x in param_grid_stage3['max_depth'] if x > 0]
    param_grid_stage3['min_child_weight'] = [x for x in param_grid_stage3['min_child_weight'] if x >= 0]
    model_stage3 = XGBRegressor(
        n_estimators=best_params['n_estimators'],
        random_state=RANDOM_STATE,
        verbosity=0,
        **device_config
    )
    grid_stage3 = GridSearchCV(model_stage3, param_grid_stage3, cv=CV_FOLDS, scoring='r2', n_jobs=1, verbose=1)
    grid_stage3.fit(X_train, y_train)
    best_params['max_depth'] = grid_stage3.best_params_['max_depth']
    best_params['min_child_weight'] = grid_stage3.best_params_['min_child_weight']
    print(
        f"步骤3完成：精调最优 max_depth={best_params['max_depth']}, min_child_weight={best_params['min_child_weight']}, CV R²={grid_stage3.best_score_:.4f}")

    print("\n[步骤 4/7] 调优 subsample & colsample_bytree ...")
    param_grid_stage4 = {
        'subsample': [0.6, 0.7, 0.8, 0.9, 1.0],
        'colsample_bytree': [0.5, 0.6, 0.7, 0.8, 0.9]
    }
    model_stage4 = XGBRegressor(
        n_estimators=best_params['n_estimators'],
        max_depth=best_params['max_depth'],
        min_child_weight=best_params['min_child_weight'],
        random_state=RANDOM_STATE,
        verbosity=0,
        **device_config
    )
    grid_stage4 = GridSearchCV(model_stage4, param_grid_stage4, cv=CV_FOLDS, scoring='r2', n_jobs=1, verbose=1)
    grid_stage4.fit(X_train, y_train)
    best_params['subsample'] = grid_stage4.best_params_['subsample']
    best_params['colsample_bytree'] = grid_stage4.best_params_['colsample_bytree']
    print(
        f"步骤4完成：最优 subsample={best_params['subsample']}, colsample_bytree={best_params['colsample_bytree']}")

    print("\n[步骤 5/7] 调优 gamma ...")
    param_grid_stage5 = {
        'gamma': [0, 0.01, 0.05, 0.1, 0.2]
    }
    model_stage5 = XGBRegressor(
        n_estimators=best_params['n_estimators'],
        max_depth=best_params['max_depth'],
        min_child_weight=best_params['min_child_weight'],
        subsample=best_params['subsample'],
        colsample_bytree=best_params['colsample_bytree'],
        random_state=RANDOM_STATE,
        verbosity=0,
        **device_config
    )
    grid_stage5 = GridSearchCV(model_stage5, param_grid_stage5, cv=CV_FOLDS, scoring='r2', n_jobs=1, verbose=1)
    grid_stage5.fit(X_train, y_train)
    best_params['gamma'] = grid_stage5.best_params_['gamma']
    print(f"步骤5完成：最优 gamma={best_params['gamma']}")

    print("\n[步骤 6/7] 调优正则化参数 reg_alpha & reg_lambda ...")
    param_grid_stage6 = {
        'reg_alpha': [0, 0.001, 0.01, 0.03, 0.08, 0.3, 0.5],
        'reg_lambda': [0, 0.001, 0.01, 0.03, 0.08, 0.3, 0.5]
    }
    model_stage6 = XGBRegressor(
        n_estimators=best_params['n_estimators'],
        max_depth=best_params['max_depth'],
        min_child_weight=best_params['min_child_weight'],
        subsample=best_params['subsample'],
        colsample_bytree=best_params['colsample_bytree'],
        gamma=best_params['gamma'],
        random_state=RANDOM_STATE,
        verbosity=0,
        **device_config
    )
    grid_stage6 = GridSearchCV(model_stage6, param_grid_stage6, cv=CV_FOLDS, scoring='r2', n_jobs=1, verbose=1)
    grid_stage6.fit(X_train, y_train)
    best_params['reg_alpha'] = grid_stage6.best_params_['reg_alpha']
    best_params['reg_lambda'] = grid_stage6.best_params_['reg_lambda']
    print(f"✅ 步骤6完成：最优 reg_alpha={best_params['reg_alpha']}, reg_lambda={best_params['reg_lambda']}")

    print("\n[步骤 7/7] 调优 learning_rate ...")
    param_grid_stage7 = {
        'learning_rate': [0.005, 0.01, 0.05, 0.1]
    }
    model_stage7 = XGBRegressor(
        n_estimators=best_params['n_estimators'],
        max_depth=best_params['max_depth'],
        min_child_weight=best_params['min_child_weight'],
        subsample=best_params['subsample'],
        colsample_bytree=best_params['colsample_bytree'],
        gamma=best_params['gamma'],
        reg_alpha=best_params['reg_alpha'],
        reg_lambda=best_params['reg_lambda'],
        random_state=RANDOM_STATE,
        verbosity=0,
        **device_config
    )
    grid_stage7 = GridSearchCV(model_stage7, param_grid_stage7, cv=CV_FOLDS, scoring='r2', n_jobs=1, verbose=1)
    grid_stage7.fit(X_train, y_train)
    best_params['learning_rate'] = grid_stage7.best_params_['learning_rate']
    print(f"步骤7完成：最优 learning_rate={best_params['learning_rate']}")

    print("\n" + "=" * 60)
    print("  所有参数调优完成，开始训练最终模型 XGBoost")
    print("=" * 60)
    time08 = time.time()
    final_model = XGBRegressor(
        **best_params,
        random_state=RANDOM_STATE,
        verbosity=0,
        **device_config
    )
    final_model.fit(X_train, y_train)
    y_pred = final_model.predict(X_test)
    result_df = pd.DataFrame({
        '真实总价(万元)': y_test.values,
        '预测总价(万元)': y_pred,
        '绝对误差(万元)': y_pred - y_test.values,
        'MAPE(%)': abs((y_pred - y_test.values) / (y_test.values + 1e-8)) * 100
    })
    mape_array = abs((y_pred - y_test) / (y_test + 1e-8))
    total_samples = len(y_test)
    mape_lt5 = mape_array[mape_array < 0.05]
    count_lt5 = len(mape_lt5)
    ratio_lt5 = (count_lt5 / total_samples) * 100
    mape_lt10 = mape_array[mape_array < 0.1]
    count_lt10 = len(mape_lt10)
    ratio_lt10 = (count_lt10 / total_samples) * 100
    mape_lt20 = mape_array[mape_array < 0.2]
    count_lt20 = len(mape_lt20)
    ratio_lt20 = (count_lt20 / total_samples) * 100
    xgb_r2 = cross_val_score(final_model, X_train, y_train, cv=CV_FOLDS, scoring='r2').mean()
    xgb_mae = -cross_val_score(final_model, X_train, y_train, cv=CV_FOLDS, scoring='neg_mean_absolute_error').mean()
    xgb_mape = np.mean(mape_array) * 100
    xgb_time = time.time() - time08
    print("\n" + "-" * 60)
    print("基于网格搜索算法对模型进行优化后，XGBoost 性能汇总：")
    print(f"运行时间: {xgb_time:.2f} 秒")
    print(f"拟合优度 (CV R²): {xgb_r2:.4f}")
    print(f"平均绝对误差 (CV MAE): {xgb_mae:.4f} 万元")
    print(f"整体平均相对误差百分比 (MAPE): {xgb_mape:.2f} %")
    print(f"\n不同精度阈值的样本统计：")
    print(f"MAPE < 5% 的样本数量: {count_lt5} / {total_samples}，占比: {ratio_lt5:.2f}%")
    print(f"MAPE < 10% 的样本数量: {count_lt10} / {total_samples}，占比: {ratio_lt10:.2f}%")
    print(f"MAPE < 20% 的样本数量: {count_lt20} / {total_samples}，占比: {ratio_lt20:.2f}%")
    print("-" * 60)
    plot_feature_importance(final_model, X_train.columns)
    plot_prediction_comparison(y_test, y_pred)

    result_path = os.path.join(desktop_path, '房价预测结果_XGBoost.csv')
    result_df.to_csv(result_path, index=False, encoding='utf-8-sig')
    print(f"预测结果已保存至: {result_path}")
    params_df = pd.DataFrame.from_dict(best_params, orient='index', columns=['最优参数值'])
    params_df.index.name = '参数名称'
    params_path = os.path.join(desktop_path, '模型最优参数_XGBoost.csv')
    params_df.to_csv(params_path, encoding='utf-8-sig')
    print(f"最优参数表已保存至: {params_path}")
    model_path = os.path.join(desktop_path, '房价预测模型_XGBoost.pkl')
    joblib.dump(final_model, model_path)
    print(f"模型已保存至: {model_path}")
    return final_model, y_pred, best_params

def plot_feature_importance(model, feature_names):
    importance = model.feature_importances_
    indices = np.argsort(importance)[-15:]
    plt.figure(figsize=(12, 8))
    plt.barh(range(len(indices)), importance[indices], color='b', align='center')
    plt.yticks(range(len(indices)), [feature_names[i] for i in indices])
    plt.xlabel('特征重要性')
    plt.title('XGBoost特征重要性')
    plt.tight_layout()
    plt.savefig(os.path.join(desktop_path, '特征重要性_XGBoost.png'), dpi=300)
    plt.close()
    print("特征重要性_XGBoost.png 已保存至桌面")

def plot_prediction_comparison(y_true, y_pred):
    plt.figure(figsize=(15, 8))
    plt.plot(y_true.values, label='真实房价',
             marker='o', markersize=3, linestyle='-', alpha=0.6)
    plt.plot(y_pred, label='预测房价',
             marker='x', markersize=3, linestyle='-', alpha=0.6)
    plt.xlabel('测试集全部样本')
    plt.ylabel('房价(万元)')
    plt.title('房价预测值与真实值对比（XGBoost 全部样本）')
    plt.legend()
    plt.grid(True, linestyle='--', alpha=0.6)
    plt.tight_layout()
    plt.savefig(os.path.join(desktop_path, '预测对比_XGBoost（全部样本）.png'), dpi=300)
    plt.close()
    print("预测对比_XGBoost（全部样本）.png 已保存至桌面")
    plt.figure(figsize=(12, 6))
    n_samples = min(100, len(y_true))
    sample_idx = range(n_samples)
    plt.plot(y_true.iloc[sample_idx].values, label='真实房价',
             marker='o', markersize=4, linestyle='-', alpha=0.7)
    plt.plot(y_pred[sample_idx], label='预测房价',
             marker='x', markersize=4, linestyle='-', alpha=0.7)
    plt.xlabel(f'测试集前{n_samples}样本')
    plt.ylabel('房价(万元)')
    plt.title(f'房价预测值与真实值对比（XGBoost 前{n_samples}样本）')
    plt.legend()
    plt.grid(True, linestyle='--', alpha=0.6)
    plt.tight_layout()
    plt.savefig(os.path.join(desktop_path, f'预测对比_XGBoost（前{n_samples}样本）.png'), dpi=300)
    plt.close()
    print(f"预测对比_XGBoost（前{n_samples}样本）.png 已保存至桌面")

def main():
    print("=" * 60)
    print("  贵阳市房价预测 - XGBoost")
    print("=" * 60)
    train, test, facilities = load_data()
    X_train, X_test, y_train, y_test = prepare_data(train, test, facilities)
    model, y_pred, best_params = train_model_paper_strategy(X_train, X_test, y_train, y_test)
    print("\n全流程处理完成！")

if __name__ == "__main__":
    main()
