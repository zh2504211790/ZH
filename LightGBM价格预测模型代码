import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import os
from sklearn.model_selection import cross_val_score, GridSearchCV, train_test_split
from sklearn.metrics import r2_score, mean_absolute_error
from lightgbm import LGBMRegressor
import time
import joblib
import warnings

warnings.filterwarnings('ignore')
plt.rcParams["font.family"] = ["SimHei", "Microsoft YaHei"]
plt.rcParams["axes.unicode_minus"] = False
desktop_path = r"C:\Users\25042\Desktop"
train_path = os.path.join(desktop_path, "训练集.csv")
test_path = os.path.join(desktop_path, "测试集.csv")


def load_data():
    print("正在加载数据...")
    train = pd.read_csv(train_path)
    test = pd.read_csv(test_path)
    print(f"训练集原始特征数量: {len(train.columns)}")
    print(f"测试集原始特征数量: {len(test.columns)}")
    return train, test

def add_features(df):
    df = df.copy()
    if '房间数量' in df.columns and '厅数量' in df.columns:
        df['房间总数'] = df['房间数量'] + df['厅数量']
    df.replace([np.inf, -np.inf], np.nan, inplace=True)
    df.fillna(0, inplace=True)
    return df

def prepare_data(train, test):
    train = add_features(train)
    test = add_features(test)
    common_features = [col for col in train.columns if col in test.columns and col != '总价']
    if '总价' not in train.columns or '总价' not in test.columns:
        raise ValueError("数据集中缺少目标变量'总价'列！")
    X_train = train[common_features]
    y_train = train['总价']
    X_test = test[common_features]
    y_test = test['总价']
    y_train_log = np.log1p(y_train)
    y_test_log = np.log1p(y_test)
    print(f"已对目标变量'总价'进行 log1p 转换")
    print(f"最终用于建模的特征数量: {len(common_features)}")
    return X_train, X_test, y_train_log, y_test_log, y_test

def train_model_paper_strategy(X_train, X_test, y_train_log, y_test_log, y_test_original):
    CV_FOLDS = 5
    RANDOM_STATE = 90
    device_config = {'device': 'cpu', 'n_jobs': 1}
    best_params = {}
    start_total_time = time.time()

    print("\n[步骤 1/6] 初始化：设置较高的初始学习率 (learning_rate=0.1) ...")
    initial_lr = 0.1
    best_params['learning_rate'] = initial_lr
    print(f"已设置初始 learning_rate = {initial_lr} (用于快速收敛)")

    print("\n[步骤 2/6] 确定 n_estimators (树的数量) ...")
    superpa = []
    n_estimators_range = range(100, 1100, 100)
    for i in n_estimators_range:
        model = LGBMRegressor(
            n_estimators=i,
            learning_rate=initial_lr,
            random_state=RANDOM_STATE,
            verbose=-1,
            **device_config
        )
        score = cross_val_score(model, X_train, y_train_log, cv=CV_FOLDS, scoring='r2').mean()
        superpa.append(score)
        print(f"n_estimators={i}, CV R²={score:.4f}")
    best_n_estimators_idx = superpa.index(max(superpa))
    best_n_estimators = list(n_estimators_range)[best_n_estimators_idx]
    best_params['n_estimators'] = best_n_estimators
    print(f"\n步骤2完成：最优 n_estimators = {best_n_estimators}, 最高CV R² = {max(superpa):.4f}")
    plt.figure(figsize=[20, 5])
    plt.plot(n_estimators_range, superpa, marker='o')
    plt.title(f'n_estimators 学习曲线 (learning_rate={initial_lr})')
    plt.xlabel('n_estimators')
    plt.ylabel('CV R² Score')
    plt.grid(True)
    plt.savefig(os.path.join(desktop_path, '步骤2_n_estimators学习曲线.png'), dpi=300)
    plt.close()
    print("学习曲线已保存至桌面")

    print("\n[步骤 3/6] 粗搜索：树结构参数 (max_depth, num_leaves, min_child_samples) ...")
    param_grid_coarse = {
        'max_depth': np.arange(3, 10, 2),
        'num_leaves': np.arange(31, 151, 40),
        'min_child_samples': [10, 20, 30]
    }
    model_coarse = LGBMRegressor(
        n_estimators=best_params['n_estimators'],
        learning_rate=best_params['learning_rate'],
        random_state=RANDOM_STATE,
        verbose=-1,
        **device_config
    )
    grid_coarse = GridSearchCV(model_coarse, param_grid_coarse, cv=CV_FOLDS, scoring='r2', n_jobs=1, verbose=1)
    grid_coarse.fit(X_train, y_train_log)
    coarse_md = grid_coarse.best_params_['max_depth']
    coarse_nl = grid_coarse.best_params_['num_leaves']
    coarse_mcs = grid_coarse.best_params_['min_child_samples']
    print(f"步骤3完成：粗搜区间中心 -> max_depth={coarse_md}, num_leaves={coarse_nl}, min_child_samples={coarse_mcs}")
    print(f"粗搜最佳 CV R² = {grid_coarse.best_score_:.4f}")

    print("\n[步骤 4/6] 精搜索：遍历最优区间 ...")
    param_grid_fine = {
        'max_depth': [coarse_md - 1, coarse_md, coarse_md + 1],
        'num_leaves': [coarse_nl - 20, coarse_nl - 10, coarse_nl, coarse_nl + 10, coarse_nl + 20],
        'min_child_samples': [coarse_mcs - 5, coarse_mcs, coarse_mcs + 5]
    }
    param_grid_fine['max_depth'] = [x for x in param_grid_fine['max_depth'] if x > 0]
    param_grid_fine['num_leaves'] = [x for x in param_grid_fine['num_leaves'] if x > 0]
    param_grid_fine['min_child_samples'] = [x for x in param_grid_fine['min_child_samples'] if x > 0]
    model_fine = LGBMRegressor(
        n_estimators=best_params['n_estimators'],
        learning_rate=best_params['learning_rate'],
        random_state=RANDOM_STATE,
        verbose=-1,
        **device_config
    )
    grid_fine = GridSearchCV(model_fine, param_grid_fine, cv=CV_FOLDS, scoring='r2', n_jobs=1, verbose=1)
    grid_fine.fit(X_train, y_train_log)
    best_params['max_depth'] = grid_fine.best_params_['max_depth']
    best_params['num_leaves'] = grid_fine.best_params_['num_leaves']
    best_params['min_child_samples'] = grid_fine.best_params_['min_child_samples']
    print(f"步骤4完成：精搜最优参数 -> max_depth={best_params['max_depth']}, num_leaves={best_params['num_leaves']}, min_child_samples={best_params['min_child_samples']}")
    print(f"精搜最佳 CV R² = {grid_fine.best_score_:.4f}")

    print("\n[步骤 5/6] 提升精度：降低学习率并按比例增加树的数量 ...")
    scale_factor = 5
    final_lr = best_params['learning_rate'] / scale_factor
    final_n_estimators = best_params['n_estimators'] * scale_factor
    print(f"初始 learning_rate: {best_params['learning_rate']} -> 最终 learning_rate: {final_lr}")
    print(f"初始 n_estimators: {best_params['n_estimators']} -> 最终 n_estimators: {final_n_estimators}")

    print("\n[步骤 6/6] 设定最优参数，训练最终模型 ...")
    best_params_final = best_params.copy()
    best_params_final['learning_rate'] = final_lr
    best_params_final['n_estimators'] = final_n_estimators
    best_params_final['subsample_freq'] = 1
    best_params_final['subsample'] = 0.8
    best_params_final['colsample_bytree'] = 0.8
    best_params_final['reg_alpha'] = 0.1
    best_params_final['reg_lambda'] = 0.1
    time08 = time.time()
    final_model = LGBMRegressor(
        **best_params_final,
        random_state=RANDOM_STATE,
        verbose=-1,
        **device_config
    )
    final_model.fit(X_train, y_train_log)
    y_pred_log = final_model.predict(X_test)
    y_pred = np.expm1(y_pred_log)
    result_df = pd.DataFrame({
        '真实总价(万元)': y_test_original.values,
        '预测总价(万元)': y_pred,
        '绝对误差(万元)': y_pred - y_test_original.values,
        'MAPE(%)': abs((y_pred - y_test_original.values) / (y_test_original.values + 1e-8)) * 100
    })
    mape_array = abs((y_pred - y_test_original) / (y_test_original + 1e-8))
    total_samples = len(y_test_original)
    mape_lt5 = mape_array[mape_array < 0.05]
    count_lt5 = len(mape_lt5)
    ratio_lt5 = (count_lt5 / total_samples) * 100
    mape_lt10 = mape_array[mape_array < 0.1]
    count_lt10 = len(mape_lt10)
    ratio_lt10 = (count_lt10 / total_samples) * 100
    mape_lt20 = mape_array[mape_array < 0.2]
    count_lt20 = len(mape_lt20)
    ratio_lt20 = (count_lt20 / total_samples) * 100
    final_r2 = r2_score(y_test_original, y_pred)
    final_mae = mean_absolute_error(y_test_original, y_pred)
    final_mape = np.mean(mape_array) * 100
    lgbm8_time = time.time() - time08
    print("\n" + "-" * 60)
    print(f"运行时间: {lgbm8_time:.2f} 秒")
    print(f"测试集 R²: {final_r2:.4f}")
    print(f"平均绝对误差 MAE: {final_mae:.4f} 万元")
    print(f"整体平均相对误差 MAPE: {final_mape:.2f} %")
    print(f"\n不同精度阈值的样本统计：")
    print(f"MAPE < 5% : {count_lt5:4d} / {total_samples}，占比: {ratio_lt5:.2f}%")
    print(f"MAPE < 10%: {count_lt10:4d} / {total_samples}，占比: {ratio_lt10:.2f}%")
    print(f"MAPE < 20%: {count_lt20:4d} / {total_samples}，占比: {ratio_lt20:.2f}%")
    print("-" * 60)
    print("\n正在生成输出文件...")
    plot_feature_importance(final_model, X_train.columns)

    plot_prediction_comparison(y_test_original, y_pred)
    result_path = os.path.join(desktop_path, '房价预测结果.csv')
    result_df.to_csv(result_path, index=False, encoding='utf-8-sig')
    print(f"预测结果已保存至: {result_path}")
    params_df = pd.DataFrame.from_dict(best_params_final, orient='index', columns=['最优参数值'])
    params_df.index.name = '参数名称'
    params_path = os.path.join(desktop_path, '模型最优参数.csv')
    params_df.to_csv(params_path, encoding='utf-8-sig')
    print(f"最优参数表已保存至: {params_path}")
    model_path = os.path.join(desktop_path, '房价预测模型.pkl')
    joblib.dump(final_model, model_path)
    print(f"模型已保存至: {model_path}")
    return final_model, y_pred, best_params_final

def plot_feature_importance(model, feature_names):
    importance = model.feature_importances_
    indices = np.argsort(importance)[-20:]
    plt.figure(figsize=(12, 10))
    plt.barh(range(len(indices)), importance[indices], color='b', align='center')
    plt.yticks(range(len(indices)), [feature_names[i] for i in indices])
    plt.xlabel('特征重要性')
    plt.title('LightGBM特征重要性 Top 20')
    plt.tight_layout()
    plt.savefig(os.path.join(desktop_path, '特征重要性_Top20.png'), dpi=300, bbox_inches='tight')
    plt.close()
    print("特征重要性_Top20.png 已保存至桌面")

def plot_prediction_comparison(y_true, y_pred):
    plt.figure(figsize=(15, 8))
    plt.plot(y_true.values, label='真实房价',
             marker='o', markersize=3, linestyle='-', alpha=0.6)
    plt.plot(y_pred, label='预测房价',
             marker='x', markersize=3, linestyle='-', alpha=0.6)
    plt.xlabel('测试集全部样本')
    plt.ylabel('房价(万元)')
    plt.title('房价预测值与真实值对比')
    plt.legend()
    plt.grid(True, linestyle='--', alpha=0.6)
    plt.tight_layout()
    plt.savefig(os.path.join(desktop_path, '预测对比_全部样本.png'), dpi=300)
    plt.close()
    print("预测对比_全部样本.png 已保存至桌面")

    plot_num = min(100, len(y_true))
    plt.figure(figsize=(15, 8))
    y_true_subset = y_true.values[:plot_num]
    y_pred_subset = y_pred[:plot_num]
    plt.plot(y_true_subset, label='真实房价',
             marker='o', markersize=5, linestyle='-', linewidth=2, color='#1f77b4')
    plt.plot(y_pred_subset, label='预测房价',
             marker='x', markersize=5, linestyle='--', linewidth=2, color='#ff7f0e')
    plt.xlabel('测试集样本(前100个)')
    plt.ylabel('房价(万元)')
    plt.title('房价预测值与真实值对比')
    plt.legend()
    plt.grid(True, linestyle='--', alpha=0.6)
    plt.tight_layout()
    plt.savefig(os.path.join(desktop_path, '预测对比_前100样本.png'), dpi=300)
    plt.close()
    print("预测对比_前100样本.png已保存至桌面")

def main():
    print("=" * 60)
    print("贵阳市房价预测")
    print("=" * 60)
    train, test = load_data()
    X_train, X_test, y_train_log, y_test_log, y_test_original = prepare_data(train, test)
    print("\n当前模型使用的特征：")
    for i, feat in enumerate(X_train.columns, 1):
        print(f"{i}. {feat}")
    model, y_pred, best_params = train_model_paper_strategy(X_train, X_test, y_train_log, y_test_log, y_test_original)
    print("\n全流程处理完成！")

if __name__ == "__main__":
    main()
